# syntax=docker/dockerfile:1

ARG BASE_IMAGE=nvcr.io/nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04
FROM ${BASE_IMAGE}

ARG DEBIAN_FRONTEND=noninteractive
ARG MAX_JOBS=8
ARG INSTALL_FLASH_ATTN=1

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=0 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    CUDA_HOME=/usr/local/cuda \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    TORCH_CUDA_ARCH_LIST="8.6;8.9;9.0" \
    MAX_JOBS=${MAX_JOBS} \
    HF_HOME=/workspace/.cache/huggingface \
    HUGGINGFACE_HUB_CACHE=/workspace/.cache/huggingface/hub \
    TRANSFORMERS_CACHE=/workspace/.cache/huggingface/transformers \
    PYTHONPATH=/workspace/RevealLayer:/workspace/RevealLayer/diffusers/src

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        git-lfs \
        libglib2.0-0 \
        libgl1 \
        ninja-build \
        python3.10 \
        python3.10-dev \
        python3-pip \
        python3-setuptools \
        python3-wheel \
    && rm -rf /var/lib/apt/lists/* \
    && git lfs install --system \
    && ln -sf /usr/bin/python3.10 /usr/local/bin/python \
    && ln -sf /usr/bin/pip3 /usr/local/bin/pip

RUN python -m pip install --upgrade pip setuptools wheel packaging ninja

WORKDIR /workspace/RevealLayer

# Install PyTorch first so xformers/flash-attn match the CUDA/PyTorch ABI.
# CUDA 12.8 + TORCH_CUDA_ARCH_LIST covers RTX A6000 (sm_86) and H20/Hopper (sm_90).
RUN python -m pip install \
        --index-url https://download.pytorch.org/whl/cu128 \
        torch==2.7.1 \
        torchvision==0.22.1

RUN python -m pip install \
        opencv-python-headless==4.10.0.84 \
        pillow==10.3.0 \
        tqdm==4.65.0 \
        mmengine==0.10.7 \
        safetensors==0.4.3 \
        huggingface-hub==0.36.0 \
        requests \
        einops==0.8.0 \
        accelerate==1.6.0 \
        transformers==4.57.1 \
        protobuf==3.20.2 \
        sentencepiece==0.1.99 \
        peft==0.15.2 \
        xformers==0.0.31.post1 \
        tensorboard \
        pyyaml \
        prodigyopt

# xformers==0.0.31.post1 requires flash-attn >=2.7.1 and <=2.8.0.
# Keep it in a separate layer because it is the slowest build step.
RUN if [ "${INSTALL_FLASH_ATTN}" = "1" ]; then \
        python -m pip install flash-attn==2.7.4.post1 --no-build-isolation && \
        python -c "import flash_attn; print('flash-attn', flash_attn.__version__)"; \
    else \
        echo "Skipping flash-attn install because INSTALL_FLASH_ATTN=${INSTALL_FLASH_ATTN}"; \
    fi

# Smoke check only imports third-party packages. Project code is mounted at runtime.
# Keep this as `python -c` because older Podman imagebuilder parses heredoc lines
# as Dockerfile instructions.
RUN python -c "import torch, torchvision, accelerate, peft, safetensors, yaml, prodigyopt; print('torch', torch.__version__, 'cuda', torch.version.cuda); print('torchvision', torchvision.__version__)"

CMD ["/bin/bash"]
