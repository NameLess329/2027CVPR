FROM docker.io/nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    DIFFSYNTH_ATTENTION_IMPLEMENTATION=torch \
    HF_HOME=/workspace/.cache/huggingface \
    MODELSCOPE_CACHE=/workspace/.cache/modelscope \
    PYTHONPATH=/workspace/Qwen_Image_Layered/src

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    libgl1 \
    libglib2.0-0 \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    python-is-python3 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel

WORKDIR /workspace/Qwen_Image_Layered

COPY docker/requirements.txt /tmp/requirements.txt
RUN python -m pip install -r /tmp/requirements.txt

COPY . /workspace/Qwen_Image_Layered

RUN chmod +x /workspace/Qwen_Image_Layered/scripts/Qwen-Image-Layered.sh \
    && mkdir -p /workspace/Qwen_Image_Layered/data \
       /workspace/Qwen_Image_Layered/models \
       /workspace/Qwen_Image_Layered/outputs \
       /workspace/.cache/huggingface \
       /workspace/.cache/modelscope

CMD ["/bin/bash"]
